# ✅ 列出所有规则 + 显示详细统计信息
iptables -L -v
# ✅ 1. 允许本地回环
iptables -A INPUT -i lo -j ACCEPT
# ✅ 2. 允许已建立连接
iptables -A INPUT -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT
# ✅ 3. 放行 SSH
iptables -A INPUT -p tcp --dport 22239 -j ACCEPT
# ✅ 4. 放行需要的端口
iptables -A INPUT -p tcp --dport 443 -j ACCEPT
# ✅ 5. 默认拒绝所有，设置 INPUT 链的默认策略 = DROP，非规则
iptables -P INPUT DROP

mkdir -p /etc/iptables/
iptables-save > /etc/iptables/rules.v4
iptables-restore < /etc/iptables/rules.v4


# ✅ 允许指定 IP访问指定端口
iptables -A INPUT -p tcp -s 1.1.1.1 --dport 443 -j ACCEPT
iptables -A INPUT -p tcp -s 2.2.2.2 --dport 443 -j ACCEPT
iptables -A INPUT -p tcp -s 3.3.3.3 --dport 443 -j ACCEPT
# ✅ 拒绝其他所有访问 443 的流量
iptables -A INPUT -p tcp --dport 443 -j DROP

# ✅ 删除制定规则
iptables -D INPUT -p tcp -s 3.3.3.3 --dport 443 -j ACCEPT

# ✅ 删除规则
# 按编号删除
# 1. 查看规则（带行号）
iptables -L INPUT -n --line-numbers

👉输出类似：
num  target  prot source      destination
1    ACCEPT  tcp  1.1.1.1     0.0.0.0/0 tcp dpt:443
2    ACCEPT  tcp  2.2.2.2     0.0.0.0/0 tcp dpt:443
3    ACCEPT  tcp  3.3.3.3     0.0.0.0/0 tcp dpt:443

# 2. 删除对应行（比如第3条）
iptables -D INPUT 3

Docker 使用 FORWARD 链转发流量，绕过了 INPUT 的 DROP 策略，需要添加DOCKER-USER 链规则
iptables -I DOCKER-USER -p tcp --dport 8317 -j DROP

查看规则（带行号）
iptables -L DOCKER-USER -n --line-numbers -v

删除方法
✅ 方法1：按行号删除
iptables -D DOCKER-USER 1
✅ 方法2：按规则删除
iptables -D DOCKER-USER -p tcp --dport 8317 -j DROP
确认是否删除成功
iptables -L DOCKER-USER -n --line-numbers -v

一键清空 DOCKER-USER
iptables -F DOCKER-USER
